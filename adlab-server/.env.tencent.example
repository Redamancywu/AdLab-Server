TZ=Asia/Shanghai

POSTGRES_DB=adlab
POSTGRES_USER=adlab
POSTGRES_PASSWORD=change-me

ADLAB_ADMIN_TOKEN=change-me

# Replace the placeholder registry below with your own Tencent TCR namespace.
POSTGRES_IMAGE=ccr.ccs.tencentyun.com/YOUR_NAMESPACE/postgres:16-alpine
NGINX_IMAGE=ccr.ccs.tencentyun.com/YOUR_NAMESPACE/nginx:1.27-alpine
GO_BASE_IMAGE=ccr.ccs.tencentyun.com/YOUR_NAMESPACE/golang:1.23-alpine
NODE_BASE_IMAGE=ccr.ccs.tencentyun.com/YOUR_NAMESPACE/node:20-alpine
BACKEND_RUNTIME_IMAGE=ccr.ccs.tencentyun.com/YOUR_NAMESPACE/alpine:3.20
ADMIN_NGINX_IMAGE=ccr.ccs.tencentyun.com/YOUR_NAMESPACE/nginx:1.27-alpine
