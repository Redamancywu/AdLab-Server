TZ=Asia/Shanghai

POSTGRES_DB=adlab
POSTGRES_USER=adlab
POSTGRES_PASSWORD=change-me

ADLAB_ADMIN_TOKEN=change-me

# Replace the placeholder namespace below with your own Alibaba Cloud ACR mirror namespace.
POSTGRES_IMAGE=registry.cn-hangzhou.aliyuncs.com/YOUR_NAMESPACE/postgres:16-alpine
NGINX_IMAGE=registry.cn-hangzhou.aliyuncs.com/YOUR_NAMESPACE/nginx:1.27-alpine
GO_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/YOUR_NAMESPACE/golang:1.23-alpine
NODE_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/YOUR_NAMESPACE/node:20-alpine
BACKEND_RUNTIME_IMAGE=registry.cn-hangzhou.aliyuncs.com/YOUR_NAMESPACE/alpine:3.20
ADMIN_NGINX_IMAGE=registry.cn-hangzhou.aliyuncs.com/YOUR_NAMESPACE/nginx:1.27-alpine
